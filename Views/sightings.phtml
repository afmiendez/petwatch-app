                            ' . $sighting->getPetBreed() . '
                            , 
                            ' . $sighting->getPetColor() . '</p>
                        <p class="card-text">
                            <strong>Location: </strong>'
                            . $sighting->getLatitude() . '
                            , 
                            ' . $sighting->getLongitude() . '</p>
                        <p class="card-text"><strong>Comment: </strong></p>
                        <textarea class="form-control" disabled>' . $sighting->getComment() . '</textarea>
