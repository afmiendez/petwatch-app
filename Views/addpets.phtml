<!-- Pagination -->
<?php if ($view->totalPages > 1) { ?>
    <nav>
        <ul class="pagination justify-content-center mt-4">

            <li class="page-item <?= ($view->currentPage <= 1) ? 'disabled' : '' ?>">
                <a class="page-link"
                   href="<?= ($view->currentPage > 1)
                           ? '?page=' . ($view->currentPage - 1)
                           . '&searchinput=' . $view->searchInput
                           . '&sortByLetters=' . $view->sortByLetters
                           . '&sortByStatus=' . $view->sortByStatus
                           : '#' ?>">«</a>
            </li>

            <?php
            $range = 2;
            for ($i = 1; $i <= $view->totalPages; $i++) {

                if ($i == 1 || $i == $view->totalPages || ($i >= $view->currentPage - $range && $i <= $view->currentPage + $range)) {

                    if ($i == 2 && $view->currentPage - $range > 2) {
                        echo '<li class="page-item disabled"><span class="page-link">…</span></li>';
                    }

                    $active = ($i == $view->currentPage) ? 'active' : '';
                    echo '<li class="page-item ' . $active . '">';
                    echo '<a class="page-link" href="?page=' . $i
                            . '&searchinput=' . $view->searchInput
                            . '&sortByLetters=' . $view->sortByLetters
                            . '&sortByStatus=' . $view->sortByStatus
                            . '">' . $i . '</a>';
                    echo '</li>';

                    if ($i == $view->totalPages - 1 && $view->currentPage + $range < $view->totalPages - 1) {
                        echo '<li class="page-item disabled"><span class="page-link">…</span></li>';
                    }
                }
            }
            ?>

            <li class="page-item <?= ($view->currentPage >= $view->totalPages) ? 'disabled' : '' ?>">
                <a class="page-link"
                   href="<?= ($view->currentPage < $view->totalPages)
                           ? '?page=' . ($view->currentPage + 1)
                           . '&searchinput=' . $view->searchInput
                           . '&sortByLetters=' . $view->sortByLetters
                           . '&sortByStatus=' . $view->sortByStatus
                           : '#' ?>">»</a>
            </li>

        </ul>
    </nav>

<?php } ?>
<?php } ?>

